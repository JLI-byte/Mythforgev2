{
  "name": "mythforge-web",
  "version": "1.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron-dev": "concurrently \"next dev\" \"cross-env NODE_ENV=development wait-on http://localhost:3000 && cross-env NODE_ENV=development electron .\"",
    "electron-build": "node scripts/build-electron.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.mythforge.app",
    "productName": "MythForge BETA 1.1",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "zip"
      ],
      "publish": null
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false
    },
    "asar": false,
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "bin/node.exe",
        "to": "node.exe"
      }
    ],
    "protocols": {
      "name": "mythforge",
      "schemes": [
        "mythforge"
      ]
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@tiptap/extension-text-align": "^3.20.0",
    "@tiptap/extension-underline": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "docx": "^9.6.0",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "fs-extra": "^11.3.4",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
